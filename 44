import tkinter as tk
from tkinter import ttk, messagebox

class GarajeApp:
    def __init__(self, root, servicio):
        self.servicio = servicio
        self.root = root
        self.root.title("Garaje App")

        # --- Formulario ---
        tk.Label(root, text="Placa:").grid(row=0, column=0, padx=5, pady=5)
        self.placa_entry = tk.Entry(root)
        self.placa_entry.grid(row=0, column=1, padx=5, pady=5)

        tk.Label(root, text="Marca:").grid(row=1, column=0, padx=5, pady=5)
        self.marca_entry = tk.Entry(root)
        self.marca_entry.grid(row=1, column=1, padx=5, pady=5)

        tk.Label(root, text="Propietario:").grid(row=2, column=0, padx=5, pady=5)
        self.propietario_entry = tk.Entry(root)
        self.propietario_entry.grid(row=2, column=1, padx=5, pady=5)

        # --- Botones ---
        tk.Button(root, text="Agregar vehículo", command=self.agregar).grid(row=3, column=0, padx=5, pady=5)
        tk.Button(root, text="Limpiar campos", command=self.limpiar_campos).grid(row=3, column=1, padx=5, pady=5)

        # --- Tabla ---
        self.tabla = ttk.Treeview(root, columns=("Placa", "Marca", "Propietario"), show="headings")
        self.tabla.heading("Placa", text="Placa")
        self.tabla.heading("Marca", text="Marca")
        self.tabla.heading("Propietario", text="Propietario")
        self.tabla.grid(row=4, column=0, columnspan=2, padx=5, pady=5)

    def agregar(self):
        placa = self.placa_entry.get().strip()
        marca = self.marca_entry.get().strip()
        propietario = self.propietario_entry.get().strip()

        if placa and marca and propietario:
            self.servicio.agregar_vehiculo(placa, marca, propietario)
            self.actualizar_tabla()
            self.limpiar_campos()
        else:
            messagebox.showwarning("Campos vacíos", "Por favor, complete todos los campos.")

    def limpiar_campos(self):
        self.placa_entry.delete(0, tk.END)
        self.marca_entry.delete(0, tk.END)
        self.propietario_entry.delete(0, tk.END)

    def actualizar_tabla(self):
        for fila in self.tabla.get_children():
            self.tabla.delete(fila)
        for v in self.servicio.listar_vehiculos():
            self.tabla.insert("", tk.END, values=(v.placa, v.marca, v.propietario))
